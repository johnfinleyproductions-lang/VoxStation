#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────
# vox — Start, stop, and check VoxStation services
#
# Usage:
#   vox              Start all services (smart — skips what's already running)
#   vox start        Same as above
#   vox stop         Stop all VoxStation services
#   vox restart      Stop then start
#   vox status       Show what's running
#   vox logs [svc]   Tail logs (voice | frontend | ollama | qdrant)
# ──────────────────────────────────────────────────────────────

set -euo pipefail

VOXSTATION_DIR="$HOME/VoxStation"
VOICE_CONTAINER="voxstation_voice"
FRONTEND_PID_FILE="$VOXSTATION_DIR/.vox-frontend.pid"

# Ports
PORT_FRONTEND=3050
PORT_VOICE=8020
PORT_OLLAMA=11434
PORT_QDRANT=6333

# GPU settings for Blackwell over OCuLink
# 1933 MHz clock locked (min=max), 186W power limit
# OCuLink bypasses the USB4/Thunderbolt tunnel so higher clocks are stable.
GPU_CLOCK_SPEED=1933
GPU_POWER_LIMIT=186

# Ollama context length — CRITICAL: without this, Ollama allocates the model's
# maximum context (262K for llama3.2:3b = 22.1 GiB VRAM). Capping at 8192
# brings llama3.2:3b down to ~3 GiB total, safely alongside the voice service.
OLLAMA_CTX=8192

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# ── Helpers ──────────────────────────────────────────────────

_log()  { echo -e "${CYAN}[vox]${NC} $*"; }
_ok()   { echo -e "${CYAN}[vox]${NC} ${GREEN}✓${NC} $*"; }
_skip() { echo -e "${CYAN}[vox]${NC} ${YELLOW}⊘${NC} $* (already running)"; }
_warn() { echo -e "${CYAN}[vox]${NC} ${YELLOW}!${NC} $*"; }
_err()  { echo -e "${CYAN}[vox]${NC} ${RED}✗${NC} $*" >&2; }

_port_listening() {
  ss -tlnp 2>/dev/null | grep -q ":$1 " && return 0
  return 1
}

_container_running() {
  docker inspect -f '{{.State.Running}}' "$1" 2>/dev/null | grep -q true
}

_wait_for_port() {
  local port=$1 name=$2 timeout=${3:-30}
  local elapsed=0
  while ! _port_listening "$port"; do
    sleep 1
    elapsed=$((elapsed + 1))
    if [ "$elapsed" -ge "$timeout" ]; then
      _err "$name did not start within ${timeout}s"
      return 1
    fi
  done
  _ok "$name is up (port $port)"
}

# ── GPU Stabilization ───────────────────────────────────────

_lock_gpu_clocks() {
  if ! command -v nvidia-smi &>/dev/null; then
    _warn "nvidia-smi not found — skipping GPU clock lock"
    return 0
  fi

  if ! nvidia-smi &>/dev/null; then
    _warn "GPU not responding — skipping clock lock (GPU may not be connected)"
    return 0
  fi

  _log "Locking GPU: ${GPU_CLOCK_SPEED} MHz, ${GPU_POWER_LIMIT}W..."
  sudo nvidia-smi -pm 1 >/dev/null 2>&1
  sudo nvidia-smi -lgc "$GPU_CLOCK_SPEED,$GPU_CLOCK_SPEED" >/dev/null 2>&1
  sudo nvidia-smi -pl "$GPU_POWER_LIMIT" >/dev/null 2>&1
  _ok "GPU clocks locked at ${GPU_CLOCK_SPEED} MHz, power limit ${GPU_POWER_LIMIT}W"
}

# ── Firewall ────────────────────────────────────────────────

_ensure_firewall() {
  if ! sudo iptables -L INPUT -n 2>/dev/null | grep -q "dpt:${PORT_FRONTEND}"; then
    _log "Opening firewall port ${PORT_FRONTEND} for LAN access..."
    sudo iptables -I INPUT -p tcp --dport "$PORT_FRONTEND" -j ACCEPT
    _ok "Firewall port ${PORT_FRONTEND} open"
  else
    _skip "Firewall port ${PORT_FRONTEND}"
  fi
}

# ── Status ───────────────────────────────────────────────────

_status() {
  echo -e "\n${BOLD}VoxStation Service Status${NC}"
  echo "────────────────────────────────────"

  if command -v nvidia-smi &>/dev/null && nvidia-smi &>/dev/null; then
    local gpu_clock
    gpu_clock=$(nvidia-smi --query-gpu=clocks.gr --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')
    local gpu_locked
    gpu_locked=$(nvidia-smi --query-gpu=clocks.max.gr --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')
    local gpu_power
    gpu_power=$(nvidia-smi --query-gpu=power.draw --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')
    if [ "$gpu_clock" = "$gpu_locked" ] 2>/dev/null; then
      echo -e "  GPU Clocks      ${GREEN}● locked${NC}   ${gpu_clock} MHz  ${gpu_power}W"
    else
      echo -e "  GPU Clocks      ${RED}● UNLOCKED${NC} ${gpu_clock} MHz ${RED}(DANGER — run vox start)${NC}"
    fi
  else
    echo -e "  GPU             ${YELLOW}○ not detected${NC}"
  fi

  if _port_listening $PORT_OLLAMA; then
    echo -e "  Ollama          ${GREEN}● running${NC}  :$PORT_OLLAMA  (ctx=${OLLAMA_CTX})"
  else
    echo -e "  Ollama          ${RED}○ stopped${NC}  :$PORT_OLLAMA"
  fi

  if _port_listening $PORT_QDRANT; then
    echo -e "  Qdrant          ${GREEN}● running${NC}  :$PORT_QDRANT"
  else
    echo -e "  Qdrant          ${RED}○ stopped${NC}  :$PORT_QDRANT"
  fi

  if _container_running "$VOICE_CONTAINER"; then
    echo -e "  Voice Service   ${GREEN}● running${NC}  :$PORT_VOICE  (STT=CUDA / TTS=CUDA)"
  else
    echo -e "  Voice Service   ${RED}○ stopped${NC}  :$PORT_VOICE"
  fi

  if [ -f "$FRONTEND_PID_FILE" ] && kill -0 "$(cat "$FRONTEND_PID_FILE")" 2>/dev/null; then
    echo -e "  Next.js         ${GREEN}● running${NC}  :$PORT_FRONTEND"
  else
    echo -e "  Next.js         ${RED}○ stopped${NC}  :$PORT_FRONTEND"
  fi

  if sudo iptables -L INPUT -n 2>/dev/null | grep -q "dpt:${PORT_FRONTEND}"; then
    echo -e "  Firewall :3050  ${GREEN}● open${NC}"
  else
    echo -e "  Firewall :3050  ${RED}● blocked${NC}  (Mac can't reach VoxStation)"
  fi

  echo ""
}

# ── Start ────────────────────────────────────────────────────

_start() {
  echo -e "\n${BOLD}Starting VoxStation${NC}"
  echo "────────────────────────────────────"

  _lock_gpu_clocks
  _ensure_firewall

  # 1. Ollama — context capped at $OLLAMA_CTX tokens
  # Without OLLAMA_CONTEXT_LENGTH, llama3.2:3b defaults to 262K context
  # which allocates 22.1 GiB VRAM. At 8192 it's ~3 GiB — safe.
  if _port_listening $PORT_OLLAMA; then
    _skip "Ollama"
  else
    _log "Starting Ollama (ctx=${OLLAMA_CTX})..."
    OLLAMA_CONTEXT_LENGTH=$OLLAMA_CTX ollama serve &>/dev/null &
    _wait_for_port $PORT_OLLAMA "Ollama" 15
  fi

  # 2. Qdrant
  if _port_listening $PORT_QDRANT; then
    _skip "Qdrant"
  else
    _log "Starting Qdrant..."
    if command -v qdrant &>/dev/null; then
      qdrant &>/dev/null &
    elif docker image ls | grep -q qdrant; then
      docker start qdrant 2>/dev/null || \
        docker run -d --name qdrant -p 6333:6333 -p 6334:6334 \
          -v "$HOME/qdrant_storage:/qdrant/storage" \
          qdrant/qdrant
    else
      _err "Qdrant not found — install it or start it manually"
    fi
    _wait_for_port $PORT_QDRANT "Qdrant" 20
  fi

  # 3. Voice Service — both STT and TTS on CUDA (cu130 nightly, sm_120 Blackwell)
  # If TTS crashes with "no kernel image available", PyTorch cu130 doesn't have
  # sm_120 support yet. In that case change VOXSTATION_XTTS_DEVICE back to cpu.
  if _container_running "$VOICE_CONTAINER"; then
    _skip "Voice Service"
  else
    _log "Starting Voice Service (STT=CUDA, TTS=CUDA)..."
    if docker start "$VOICE_CONTAINER" 2>/dev/null; then
      :
    else
      _log "Creating new voice container..."
      cd "$VOXSTATION_DIR/voice-service"
      if ! docker image inspect voxstation-voice &>/dev/null; then
        _log "Building voice image (first time — takes ~10 min)..."
        docker build -t voxstation-voice .
      fi
      docker run -d \
        --name "$VOICE_CONTAINER" \
        --gpus all \
        -p 8020:8020 \
        -v ./models:/app/models \
        -v ./voices:/app/voices \
        -e VOXSTATION_WHISPER_MODEL=large-v2 \
        -e VOXSTATION_WHISPER_DEVICE=cuda \
        -e VOXSTATION_XTTS_DEVICE=cuda \
        voxstation-voice
      cd "$VOXSTATION_DIR"
    fi
    _wait_for_port $PORT_VOICE "Voice Service" 90
  fi

  # 4. Next.js Frontend
  if [ -f "$FRONTEND_PID_FILE" ] && kill -0 "$(cat "$FRONTEND_PID_FILE")" 2>/dev/null; then
    _skip "Next.js frontend"
  else
    _log "Starting Next.js frontend..."
    cd "$VOXSTATION_DIR"
    if [ ! -d ".next" ]; then
      _log "Building Next.js (first time)..."
      npm run build
    fi
    npm start > "$VOXSTATION_DIR/.vox-frontend.log" 2>&1 &
    echo $! > "$FRONTEND_PID_FILE"
    _wait_for_port $PORT_FRONTEND "Next.js frontend" 20
  fi

  echo ""
  _ok "${BOLD}VoxStation is ready!${NC}"
  echo -e "    Open ${CYAN}http://192.168.4.176:3050${NC} in your browser"
  echo ""
}

# ── Stop ─────────────────────────────────────────────────────

_stop() {
  echo -e "\n${BOLD}Stopping VoxStation${NC}"
  echo "────────────────────────────────────"

  if [ -f "$FRONTEND_PID_FILE" ]; then
    local pid
    pid=$(cat "$FRONTEND_PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null
      _ok "Next.js frontend stopped"
    fi
    rm -f "$FRONTEND_PID_FILE"
  else
    _log "Next.js frontend not tracked (may not be running)"
  fi

  if _container_running "$VOICE_CONTAINER"; then
    docker stop "$VOICE_CONTAINER" >/dev/null
    _ok "Voice Service stopped"
  else
    _log "Voice Service not running"
  fi

  if pgrep -x ollama &>/dev/null; then
    pkill -x ollama 2>/dev/null || true
    _ok "Ollama stopped"
  else
    _log "Ollama not running"
  fi

  echo ""
  _ok "VoxStation stopped"
  echo ""
}

# ── Logs ─────────────────────────────────────────────────────

_logs() {
  local svc="${1:-voice}"
  case "$svc" in
    voice)    docker logs -f "$VOICE_CONTAINER" ;;
    frontend) tail -f "$VOXSTATION_DIR/.vox-frontend.log" ;;
    ollama)   journalctl -u ollama -f 2>/dev/null || _err "Ollama logs not available via journalctl" ;;
    qdrant)   docker logs -f qdrant 2>/dev/null || _err "Qdrant logs not available" ;;
    *)        _err "Unknown service: $svc (use: voice, frontend, ollama, qdrant)" ;;
  esac
}

# ── Main ─────────────────────────────────────────────────────

case "${1:-start}" in
  start)    _start ;;
  stop)     _stop ;;
  restart)  _stop; sleep 2; _start ;;
  status)   _status ;;
  logs)     _logs "${2:-voice}" ;;
  -h|--help|help)
    echo "Usage: vox [start|stop|restart|status|logs [service]]"
    echo ""
    echo "Commands:"
    echo "  start     Start all services (default, skips what's already up)"
    echo "  stop      Stop all VoxStation services"
    echo "  restart   Stop then start"
    echo "  status    Show service status"
    echo "  logs      Tail logs (voice|frontend|ollama|qdrant)"
    ;;
  *)
    _err "Unknown command: $1"
    echo "Usage: vox [start|stop|restart|status|logs [service]]"
    exit 1
    ;;
esac
