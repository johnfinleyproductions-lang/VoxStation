# VoxStation Voice Service
VOXSTATION_HOST=0.0.0.0
VOXSTATION_PORT=8020

# Whisper STT
VOXSTATION_WHISPER_MODEL=large-v3
VOXSTATION_WHISPER_DEVICE=cuda
VOXSTATION_WHISPER_COMPUTE_TYPE=float16

# XTTS v2 TTS
VOXSTATION_XTTS_DEVICE=cuda

# CORS (add your frontend URL)
VOXSTATION_CORS_ORIGINS=["http://localhost:3050","http://192.168.4.165:3050"]
